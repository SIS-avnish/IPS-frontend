{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "react-snap",
    "dev:ssr": "node server.js",
    "build:ssr": "vite build && cross-env SSR=true vite build",
    "start:ssr": "cross-env NODE_ENV=production node server.js",
    "preview": "vite preview",
    "lint": "eslint ."
  },
  "reactSnap": {
    "source": "dist/client",
    "minifyHtml": {
      "collapseWhitespace": true,
      "removeComments": true
    },
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox",
      "--disable-dev-shm-usage"
    ],
    "port": 45695,
    "concurrency": 2,
    "skipThirdPartyRequests": false,
    "userAgent": "ReactSnap-Prerenderer",
    "exclude": [
      "/ipsa/ipsadmissions",
      "/activities/social"
    ],
    "puppeteer": {
      "navigationOptions": {
        "timeout": 60000,
        "waitUntil": "networkidle2"
      }
    }
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@tailwindcss/vite": "^4.1.18",
    "axios": "^1.13.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "dompurify": "^3.4.5",
    "express": "^5.2.1",
    "framer-motion": "^12.34.0",
    "isomorphic-dompurify": "^3.14.0",
    "lucide-react": "^0.564.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.13.0",
    "swiper": "^12.1.2",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "node-fetch": "^3.3.2",
    "react-snap": "^1.23.0",
    "shadcn": "^3.8.4",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.3.1"
  }
}
